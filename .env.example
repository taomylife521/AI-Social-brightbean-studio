# CORE
SECRET_KEY=change-me-to-a-random-string
ENCRYPTION_KEY_SALT=change-me-to-a-random-string
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1
APP_URL=http://localhost:8000

# DATABASE
DATABASE_URL=postgres://postgres:postgres@localhost:5432/brightbean

# STORAGE
STORAGE_BACKEND=local
MEDIA_ROOT=/app/media
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
S3_CUSTOM_DOMAIN=
S3_REGION_NAME=auto

# EMAIL
EMAIL_BACKEND_TYPE=smtp
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# GOOGLE AUTH (user login/signup - separate from platform credentials below)
GOOGLE_AUTH_CLIENT_ID=
GOOGLE_AUTH_CLIENT_SECRET=

# PLATFORM CREDENTIALS — set per deployment here (these take precedence), or
# per organization via the Django admin at /admin/ -> Platform credentials.
PLATFORM_FACEBOOK_APP_ID=
PLATFORM_FACEBOOK_APP_SECRET=
PLATFORM_INSTAGRAM_APP_ID=
PLATFORM_INSTAGRAM_APP_SECRET=
# LinkedIn - see README "LinkedIn" section. Choose Path A or Path B (or both).
# Path B (Community Management API) credentials are automatically reused for
# personal connections, giving refresh tokens + inbox.
PLATFORM_LINKEDIN_PERSONAL_CLIENT_ID=
PLATFORM_LINKEDIN_PERSONAL_CLIENT_SECRET=
PLATFORM_LINKEDIN_COMPANY_CLIENT_ID=
PLATFORM_LINKEDIN_COMPANY_CLIENT_SECRET=
# Legacy shared vars (still honored as fallback for both personal + company,
# assumed to be CM-approved). Leave commented unless migrating from an older install.
# PLATFORM_LINKEDIN_CLIENT_ID=
# PLATFORM_LINKEDIN_CLIENT_SECRET=
PLATFORM_TIKTOK_CLIENT_KEY=
PLATFORM_TIKTOK_CLIENT_SECRET=
PLATFORM_GOOGLE_CLIENT_ID=
PLATFORM_GOOGLE_CLIENT_SECRET=
PLATFORM_PINTEREST_APP_ID=
PLATFORM_PINTEREST_APP_SECRET=

# UNSPLASH — optional; enables stock-photo search in the composer.
# Create a free app at https://unsplash.com/developers and paste its Access Key.
UNSPLASH_ACCESS_KEY=

# INBOUND WEBHOOKS
FACEBOOK_WEBHOOK_VERIFY_TOKEN=
INSTAGRAM_LOGIN_WEBHOOK_VERIFY_TOKEN=
YOUTUBE_WEBHOOK_SECRET=

# INTELLIGENCE — optional hosted SaaS integration.
# All five vars must be set for the Intelligence menu item / billing flow
# to appear. Leave any blank to keep Studio in vanilla OSS mode (no Stripe,
# no left-nav Intelligence entry, no /orgs/<id>/intelligence/ URLs).
# - INTELLIGENCE_INTERNAL_URL: hosted Intelligence's /internal/v1/ base
# - INTELLIGENCE_PUBLIC_URL:   hosted Intelligence's /v1/ base
# - STUDIO_DEPLOYMENT_ID:      must match the value registered on the
#                              Intelligence side via register_studio_deployment
# - STUDIO_SHARED_SECRET:      HMAC secret for this deployment (Intelligence-issued)
# - STUDIO_BASE_URL:           https:// URL of THIS Studio deployment.
#                              Validated at boot — non-https raises
#                              ImproperlyConfigured.
INTELLIGENCE_INTERNAL_URL=
INTELLIGENCE_PUBLIC_URL=
STUDIO_DEPLOYMENT_ID=
STUDIO_SHARED_SECRET=
STUDIO_BASE_URL=

# MCP OAUTH — optional. The /api/v1/mcp endpoint accepts a native OAuth login
# (e.g. Claude Desktop → "Add custom connector") in addition to bb_studio_ API
# keys. Both URLs default to APP_URL; set them only for a split app/api
# deployment. In production they must be the public https origin Claude reaches.
# MCP_PUBLIC_BASE_URL=https://your-studio.example.com
# MCP_OAUTH_ISSUER_URL=https://your-studio.example.com

